<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}{% if title %} · {% endif %}Research Notes</title>
  <meta name="description" content="Notes and write-ups from ongoing research experiments.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="page">
    <header class="site-header">
      <a class="site-title" href="/">Research Notes</a>
      <p class="site-subtitle">Experiments, write-ups, and the occasional dead end.</p>
      <nav>
        <a href="/">Posts</a>
        <a href="/about/">About</a>
      </nav>
    </header>
    <hr class="rule">
    <main>
      {{ content | safe }}
    </main>
    <hr class="rule">
    <footer class="site-footer">
      <p>&copy; {% year %} &middot; built with <a href="https://www.11ty.dev/">Eleventy</a></p>
    </footer>
  </div>
</body>
</html>
